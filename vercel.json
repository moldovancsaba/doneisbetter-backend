{
"buildCommand": "cd frontend && npm install && npm run build",
"outputDirectory": "frontend/dist",
"framework": "vite",
"rewrites": [
    {
    "source": "/api/(.*)",
    "destination": "/api/$1"
    }
],
"builds": [
    {
    "src": "frontend/package.json",
    "use": "@vercel/static-build"
    }
]
}
